# API 인증 정보 (환경 변수로도 설정 가능: NAVER_CLIENT_ID, NAVER_CLIENT_SECRET, GEMINI_API_KEY)
api:
  naver:
    client_id: "YOUR_NAVER_CLIENT_ID"
    client_secret: "YOUR_NAVER_CLIENT_SECRET"
  gemini:
    api_key: "YOUR_GEMINI_API_KEY"
    model: "gemini-2.5-flash-lite"

# RSS 피드 소스 (정책브리핑 korea.kr)
rss_sources:
  공정거래: "https://www.korea.kr/rss/dept_ftc.xml"
  소비자보호: "https://www.korea.kr/rss/dept_mfds.xml"
  개인정보: "https://www.korea.kr/rss/dept_pipc.xml"
  노동: "https://www.korea.kr/rss/dept_moel.xml"
  콘텐츠/저작권: "https://www.korea.kr/rss/dept_mcst.xml"
  안전: "https://www.korea.kr/rss/dept_mois.xml"
  AI/자동화: "https://www.korea.kr/rss/dept_msit.xml"

# 뉴스 검색 키워드 (카테고리별)
news_query_categories:
  공정거래:
    - "자사우대"
    - "수수료"
    - "독점"
    - "공정거래"
    - "온라인플랫폼공정화법"
    - "플랫폼 규제"
  소비자보호:
    - "허위리뷰"
    - "다크패턴"
    - "가품"
    - "이용자 보호"
    - "환불"
    - "기만광고"
  개인정보:
    - "개인정보"
    - "위치정보"
    - "개인정보 유출"
    - "프라이버시"
    - "데이터 활용"
  노동:
    - "플랫폼 노동"
    - "라이더"
    - "배달기사"
    - "근로자성"
    - "노동권"
  콘텐츠/저작권:
    - "저작권"
    - "콘텐츠 대가"
    - "불법복제"
    - "학습데이터"
    - "생성형AI 저작권"
  안전:
    - "위해상품"
    - "리콜"
    - "안전"
    - "불법판매"
    - "소비자 안전"
  AI/자동화:
    - "AI 규제"
    - "알고리즘"
    - "추천 시스템"
    - "자동화"
    - "생성형 AI"

# 플랫폼명 사전
platforms:
  domestic:
    - "네이버"
    - "카카오"
    - "쿠팡"
    - "배달의민족"
    - "요기요"
    - "당근"
    - "토스"
    - "야놀자"
    - "무신사"
    - "직방"
    - "오늘의집"
    - "카카오모빌리티"
    - "네이버쇼핑"
  foreign:
    - "구글"
    - "유튜브"
    - "메타"
    - "인스타그램"
    - "페이스북"
    - "틱톡"
    - "아마존"
    - "테무"
    - "알리익스프레스"
    - "우버"
    - "넷플릭스"
    - "오픈AI"

# 기관명 사전
institutions:
  - "공정거래위원회"
  - "개인정보보호위원회"
  - "방송통신위원회"
  - "과학기술정보통신부"
  - "문화체육관광부"
  - "고용노동부"
  - "행정안전부"
  - "식품의약품안전처"
  - "국회"
  - "산업통상자원부"

# 정책 영역
policy_domains:
  - "공정거래"
  - "소비자보호"
  - "개인정보"
  - "노동"
  - "콘텐츠/저작권"
  - "안전"
  - "AI/자동화"

# 리스크 평가 설정
risk:
  threshold: 70
  trending_ratio: 2.0
